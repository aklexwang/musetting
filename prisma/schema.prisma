// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
// Transaction 테이블 생성: npx prisma db push (또는 npm run db:push)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 본사 어드민: 가맹점(프랜차이즈) 목록
model Franchise {
  id           String   @id @default(cuid())
  name         String   // 가맹점명
  password     String?  // 가맹점 어드민 로그인용 (해시)
  contact      String?  // 연락처 @아이디
  telegramCode String?  // 텔봇코드
  apiUrl       String?  // 로그인 API 주소
  status       String   @default("ACTIVE") // ACTIVE | SUSPENDED
  token        String?  // Token
  memberUrl    String?  // 회원 URL
  remark       String?  // 비고
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
}

model User {
  id             String        @id @default(cuid())
  franchiseId    String?       // 본사 연동: 소속 가맹점
  franchise      Franchise?    @relation(fields: [franchiseId], references: [id], onDelete: SetNull)
  username       String        @unique
  password       String
  bankName       String
  accountNumber  String
  accountHolder  String
  role           String        @default("USER")
  status         String        @default("PENDING")
  canBuy         Boolean       @default(false)
  canSell        Boolean       @default(false)
  suspended      Boolean       @default(false)
  terminated     Boolean       @default(false)  // 해지 여부 (정상/정지/해지)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions           Transaction[]
  accountChangeRequests AccountChangeRequest[]
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // BUY | SELL
  amount        Int      // 금액 (원)
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  apiStatus     String   @default("IDLE")   // IDLE | SUCCESS | FAILED
  axpayOrderId  String?  // AxPay 로그인 API 성공 시 order_id
  axpayUrl      String?  // AxPay 로그인 API 성공 시 url (iframe용)
  createdAt     DateTime @default(now())
}

model AccountChangeRequest {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  beforeHolder    String   // 변경 전 예금주
  beforeBank      String   // 변경 전 은행명
  beforeAccount   String   // 변경 전 계좌번호
  afterHolder     String   // 변경 후 예금주
  afterBank       String   // 변경 후 은행명
  afterAccount    String   // 변경 후 계좌번호
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt       DateTime @default(now())
  processedAt     DateTime? // 승인/거부 처리 일시
  processedVia    String?  // "telegram" | "admin" - 텔레그램에서 처리한 내역만 어드민에 표시
}
